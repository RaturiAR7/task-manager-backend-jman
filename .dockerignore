# Dependencies (node_modules is usually installed inside the container)
node_modules
# Next.js build outputs (always generated during `next build`)
.next/
out/
dist/
build/
# Environment variables
.env
.env*.local
.env.development
.env.test
.env.production.local
# Local development and editor files
.git/
.gitignore
.gitattributes
.vscode/
.idea/
# Testing and coverage output
coverage/
.nyc_output/
__tests__/
__mocks__/
cypress/
# Docker configuration files (not needed inside the build context)
Dockerfile*
.dockerignore
docker-compose*.yml
# Cache directories and temporary data
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.turbo/
.tmp/
.temp/
# TypeScript build metadata
*.tsbuildinfo
# OS-specific junk
.DS_Store
Thumbs.db
